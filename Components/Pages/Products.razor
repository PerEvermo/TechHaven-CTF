@page "/products"
@rendermode InteractiveServer
@inject DatabaseService Db

<PageTitle>Products — TechHaven Electronics</PageTitle>

<div class="search-section">
    <div class="container">
        <div class="row align-items-center g-2">
            <div class="col-md-8">
                <input @bind="searchTerm"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown"
                       class="form-control form-control-lg"
                       placeholder="Search products…"
                       autocomplete="off" />
                <!-- TODO: sanitize search input before passing to DB query -->
                <!-- Debug: query = SELECT id, name, description, price, category FROM products WHERE name LIKE '%query%' -->
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-lg w-100" @onclick="Search">Search</button>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary btn-lg w-100" @onclick="Reset">Reset</button>
            </div>
        </div>
        @if (errorMessage is not null)
        {
            <div class="alert alert-danger mt-2 mb-0 py-2">@errorMessage</div>
        }
    </div>
</div>

<div class="container py-4">

    @* Category filter strip — also doubles as a CTF entry point via ?cat= URL parameter *@
    @* Debug: query = SELECT id, name, description, price, category FROM products WHERE category = 'cat' *@
    <div class="mb-4 d-flex flex-wrap gap-2 align-items-center">
        <span class="text-muted small me-1">Filter by category:</span>
        @foreach (var cat in categories)
        {
            <a href="/products?cat=@Uri.EscapeDataString(cat)"
               class="btn btn-sm @(activeCategory == cat ? "btn-dark" : "btn-outline-secondary")">
                @cat
            </a>
        }
        @if (activeCategory is not null)
        {
            <a href="/products" class="btn btn-sm btn-outline-danger">&#x2715; Clear</a>
        }
    </div>

    @if (categoryError is not null)
    {
        <div class="alert alert-danger">Database error: @categoryError</div>
    }

    @if (isSearching)
    {
        <p class="text-muted">Searching for "<strong>@lastSearch</strong>"…</p>
    }

    @if (products.Count == 0 && lastSearch is not null)
    {
        <div class="alert alert-info">No products found for "<strong>@lastSearch</strong>".</div>
    }
    else
    {
        @if (lastSearch is not null)
        {
            <p class="text-muted mb-3">@products.Count result(s) for "<strong>@lastSearch</strong>"</p>
        }

        <div class="row g-4">
            @foreach (var p in products)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card product-card border-0 shadow-sm h-100">
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary category-badge mb-2 align-self-start">@p.Category</span>
                            <h5 class="card-title">@p.Name</h5>
                            <p class="card-text text-muted flex-grow-1">@p.Description</p>
                            <div class="mt-3 d-flex justify-content-between align-items-center">
                                <span class="price-tag">@p.Price.ToString("N2") kr</span>
                                <a href="/product/@p.Id" class="btn btn-outline-primary btn-sm">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (lastSearch is null && activeCategory is null)
    {
        <div class="row g-4">
            @foreach (var p in allProducts)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card product-card border-0 shadow-sm h-100">
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary category-badge mb-2 align-self-start">@p.Category</span>
                            <h5 class="card-title">@p.Name</h5>
                            <p class="card-text text-muted flex-grow-1">@p.Description</p>
                            <div class="mt-3 d-flex justify-content-between align-items-center">
                                <span class="price-tag">@p.Price.ToString("N2") kr</span>
                                <a href="/product/@p.Id" class="btn btn-outline-primary btn-sm">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* FLAG 2: hidden div — discoverable via DevTools or View Page Source *@
        <div id="__debug" style="display:none;" aria-hidden="true">RkxBRzI6IFNIQURPV18wMg==</div>
    }

    <div class="mt-5 p-3 bg-light rounded border">
        <p class="mb-1 small text-muted">&#x1F6D2; <strong>Ready to buy?</strong> Head to our <a href="/checkout">checkout page</a> to apply discount codes and complete your order.</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "cat")]
    public string? CategoryParam { get; set; }

    private string searchTerm = "";
    private string? lastSearch;
    private bool isSearching;
    private string? errorMessage;
    private string? categoryError;
    private string? activeCategory;
    private List<ProductResult> products = new();
    private List<ProductResult> allProducts = new();
    private List<string> categories = new();

    protected override void OnInitialized()
    {
        allProducts = Db.GetAllProducts();
        categories = allProducts.Select(p => p.Category).Distinct().OrderBy(c => c).ToList();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(CategoryParam))
        {
            activeCategory = CategoryParam;
            try
            {
                // FLAG 16: SQLCAT_16 — this query is vulnerable to UNION injection via the ?cat= URL parameter
                // Try: /products?cat=Laptops' UNION SELECT 1,secret_key,secret_value,0.0,'SECRET' FROM secrets --
                products = Db.SearchByCategoryVulnerable(CategoryParam);
                categoryError = null;
            }
            catch (Exception ex)
            {
                categoryError = ex.Message;
                products = new();
            }
        }
        else
        {
            activeCategory = null;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Search();
    }

    private void Search()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            Reset();
            return;
        }

        isSearching = true;
        lastSearch = searchTerm;
        activeCategory = null;

        try
        {
            products = Db.SearchProductsVulnerable(searchTerm);
        }
        catch (Exception ex)
        {
            // Intentionally leaks DB error — realistic misconfiguration
            errorMessage = $"Database error: {ex.Message}";
            products = new();
        }
        finally
        {
            isSearching = false;
        }
    }

    private void Reset()
    {
        searchTerm = "";
        lastSearch = null;
        errorMessage = null;
        products = new();
    }
}
