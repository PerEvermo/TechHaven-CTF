@page "/forgot-password"
@rendermode InteractiveServer
@inject DatabaseService Db

<PageTitle>Forgot Password — TechHaven Electronics</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <h3 class="fw-bold mb-1">Reset Password</h3>
                    <p class="text-muted mb-4">Enter your username and we'll look up your account.</p>

                    @if (message is not null)
                    {
                        <div class="alert @(isSuccess ? "alert-success" : "alert-info")">@message</div>
                    }

                    @if (results is not null && results.Count > 0)
                    {
                        <div class="alert alert-warning">
                            @foreach (var r in results)
                            {
                                <div><strong>@r.Username</strong> — token: <code>@r.ResetToken</code></div>
                            }
                        </div>
                    }

                    @if (errorMessage is not null)
                    {
                        <div class="alert alert-danger">Database error: @errorMessage</div>
                    }

                    <div class="mb-4">
                        <label class="form-label">Username</label>
                        <input @bind="username" class="form-control" placeholder="Enter your username" />
                    </div>

                    <button class="btn btn-primary w-100" @onclick="Submit">Send Reset Link</button>

                    <hr class="my-4" />
                    <p class="text-muted small mb-0">
                        Remembered it? <a href="/login">Back to Login</a>
                    </p>
                </div>
            </div>

            <div class="ctf-hint mt-3">
                <strong>Dev note:</strong> Password reset emails are not yet implemented.
                This form currently returns the raw DB result for debugging.
                <!-- TODO: remove raw DB output before launch -->
                <!-- Debug: SELECT username, password FROM users WHERE username = 'input' -->
                <!-- TODO: wire up newsletter_subscribers(id, email, token) for post-reset re-engagement emails -->
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string? message;
    private string? errorMessage;
    private bool isSuccess;
    private List<ForgotPasswordResult>? results;

    private void Submit()
    {
        message = null;
        errorMessage = null;
        results = null;

        if (string.IsNullOrWhiteSpace(username)) return;

        try
        {
            // FLAG 18: SQLFORGOT_18 — vulnerable to SQL injection
            // Try: ' UNION SELECT email, token FROM newsletter_subscribers --
            // (must match 2-column SELECT: username, password)
            results = Db.ForgotPasswordVulnerable(username);

            if (results.Count > 0)
            {
                message = $"Account found. A reset link has been sent (email system under maintenance).";
                isSuccess = true;
            }
            else
            {
                message = "No account found with that username.";
                isSuccess = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}
