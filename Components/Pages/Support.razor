@page "/support"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Support — TechHaven Electronics</PageTitle>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="fw-bold mb-2">Support Centre</h1>
            <p class="lead text-muted mb-5">Need help? We've got you covered.</p>

            <h4 class="fw-bold mb-3">Frequently Asked Questions</h4>

            <div class="accordion mb-5" id="faqAccordion">
                <div class="accordion-item border-0 shadow-sm mb-2">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                            How long does delivery take?
                        </button>
                    </h2>
                    <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Standard delivery within Norway takes 2–4 business days. Express next-day delivery is available at checkout for most addresses.
                        </div>
                    </div>
                </div>
                <div class="accordion-item border-0 shadow-sm mb-2">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                            What is your return policy?
                        </button>
                    </h2>
                    <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            We offer a 30-day hassle-free return policy. Items must be in original packaging and unused condition. Contact us to initiate a return.
                        </div>
                    </div>
                </div>
                <div class="accordion-item border-0 shadow-sm mb-2">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                            Do products come with a warranty?
                        </button>
                    </h2>
                    <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Yes — all products sold by TechHaven carry a minimum 2-year warranty in line with Norwegian consumer law.
                        </div>
                    </div>
                </div>
                <div class="accordion-item border-0 shadow-sm mb-2">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                            How do I track my order?
                        </button>
                    </h2>
                    <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Once your order ships you will receive an email with a tracking link. You can also check order status by logging into your account.
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="fw-bold mb-3">Contact Us</h4>
            <ul class="list-unstyled mb-5">
                <li class="mb-1">&#x1F4E7; <a href="mailto:support@techhaven.no">support@techhaven.no</a></li>
                <li class="mb-1">&#x1F4DE; +47 22 00 00 00 &mdash; Mon&ndash;Fri 08:00&ndash;17:00</li>
                <li>&#x1F4AC; Live chat available in the bottom-right corner during business hours</li>
            </ul>

            <div class="ctf-hint mt-4">
                <strong>Developer note:</strong> This support portal is fully instrumented.
                Diagnostic events are logged on page load &mdash; check your browser&rsquo;s developer tools console if something looks off.
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // FLAG 21: CONSOLELOG_21 — accidentally left debug log in production
            await JS.InvokeVoidAsync("printSupportDebug", "CONSOLELOG_21");
        }
    }
}
