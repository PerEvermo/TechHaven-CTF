            await JS.InvokeVoidAsync("setCookie", "customer_tier", "standard", 7);
            // FLAG 10: LOCALSTORAGE_10 — stored in localStorage as a debug session token
            // Base64 decodes to: "FLAG10: LOCALSTORAGE_10"
            await JS.InvokeVoidAsync("setLocalStorage", "th_debug_token", "RkxBRzEwOiBMT0NBTFNUT1JBR0VfMTA=");
        }
    }
}
